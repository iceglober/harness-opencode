# npm package artifacts (never checked in)
node_modules/
dist/
*.tgz

# Install-time artifacts (never checked in)
.manifest

# Auto-updater state + concurrency lock. Live inside the checkout so users
# can inspect them (~/.glorious/opencode/.auto-update-state.json). Must be
# ignored so (a) contributors running the tool against their checkout don't
# dirty their tree, and (b) the plugin's own "dirty-tree → skip" gate
# doesn't self-trip the first time it writes state.
/.auto-update-state.json
/.auto-update.lock
.auto-update-state.json.tmp.*

# Created by install.sh when running against a local checkout — see issue #10.
# install.sh symlinks this path to ~/.config/opencode/node_modules so tool
# files (whose realpath is inside home/) can resolve their npm deps.
home/.config/opencode/node_modules

# Editor / OS junk
.DS_Store
*.swp
*~

# Orchestrator / subagent scratch (plans, memory, todo traces). Agents in
# this repo write to .agent/ per their own convention; it's never part of a
# PR's payload.
.agent/

# Cost-tracker plugin data. Default location is ~/.glorious/opencode/, which
# is this checkout when contributors work against a local clone. Ignored so
# running a session in-tree doesn't dirty the working tree. User-overridable
# via GLORIOUS_COST_TRACKER_DIR.
/costs.json
/costs.jsonl
/costs.json.tmp.*

# Serena MCP per-project cache. Created by `serena_activate_project` when an
# agent uses Serena's symbol tools in this checkout. Contains an indexed
# symbol cache + project-local memories; regenerated on demand. Never
# checked in.
.serena/
