{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "autoupdate": false,
  "plugin": [
    "some-user-plugin",
    "another-user-plugin",
    "opencode-hashline"
  ],
  "formatter": {
    "prettier": {
      "disabled": true
    }
  },
  "agent": {
    "reviewer": {
      "description": "User-defined review-only agent",
      "mode": "subagent",
      "model": "anthropic/claude-haiku-4-5",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "rm -rf *": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny"
    },
    "external_directory": {
      "~/.glorious/worktrees/**": "allow"
    }
  },
  "mcp": {
    "memory": {
      "type": "local",
      "command": [
        "bash",
        "-c",
        "exec bash \"$HOME/.config/opencode/bin/memory-mcp-launcher.sh\""
      ],
      "enabled": true
    }
  }
}
