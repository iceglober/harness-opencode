{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "prime",
  "plugin": [
    "opencode-hashline"
  ],
  "permission": {
    "bash": {
      "*": "allow",
      "rm -rf *": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny"
    },
    "external_directory": {
      "~/scratch/**": "allow",
      "~/.glorious/worktrees/**": "allow"
    }
  },
  "mcp": {
    "memory": {
      "type": "local",
      "command": [
        "bash",
        "-c",
        "exec bash \"$HOME/.config/opencode/bin/memory-mcp-launcher.sh\""
      ],
      "enabled": true
    }
  }
}
