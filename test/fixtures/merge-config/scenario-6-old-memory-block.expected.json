{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "prime",
  "plugin": ["opencode-hashline"],
  "mcp": {
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true,
      "environment": {
        "MEMORY_FILE_PATH": ".agent/memory.json"
      }
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "rm -rf *": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny"
    },
    "external_directory": {
      "~/.glorious/worktrees/**": "allow"
    }
  }
}
