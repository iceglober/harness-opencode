{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "plugin": ["opencode-hashline"],
  "permission": {
    "bash": {
      "*": "allow",
      "rm -rf *": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny"
    },
    "external_directory": "ask"
  }
}
