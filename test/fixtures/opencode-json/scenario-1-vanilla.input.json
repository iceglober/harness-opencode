{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "model": "anthropic/claude-opus-4-7",
  "plugin": ["opencode-hashline"],
  "permission": {
    "bash": {
      "*": "allow",
      "rm -rf *": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny"
    }
  }
}
