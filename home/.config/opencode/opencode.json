{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "plugin": ["opencode-hashline"],
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context=ide-assistant",
        "--open-web-dashboard",
        "false"
      ],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": ["bash", "-c", "exec bash \"$HOME/.config/opencode/bin/memory-mcp-launcher.sh\""],
      "enabled": true
    },
    "git": {
      "type": "local",
      "command": ["uvx", "mcp-server-git"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": false
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": false
    }
  },
  "agent": {
    "orchestrator": {
      "description": "End-to-end orchestrator. Takes a request from intent to ready-to-ship in one session. Default primary agent.",
      "mode": "primary",
      "model": "anthropic/claude-opus-4-7",
      "temperature": 0.2,
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "git push *": "allow",
          "git push --force*": "deny",
          "git push -f *": "deny",
          "git push * main*": "deny",
          "git push * master*": "deny",
          "git clean *": "deny",
          "git reset --hard*": "ask",
          "git checkout *": "ask",
          "git worktree *": "ask",
          "rm -rf *": "deny",
          "chmod +x *": "allow",
          "chmod -x *": "allow",
          "chmod *": "deny",
          "chown *": "deny",
          "sudo *": "deny"
        },
        "webfetch": "allow",
        "ast_grep": "allow",
        "tsc_check": "allow",
        "eslint_check": "allow",
        "todo_scan": "allow",
        "comment_check": "allow",
        "question": "allow",
        "serena": "allow",
        "memory": "allow",
        "git": "allow",
        "playwright": "allow",
        "linear": "allow"
      },
      "prompt": "{file:../../.claude/agents/orchestrator.md}"
    },
    "plan": {
      "description": "Interactive planner. Orchestrates gap analysis and adversarial review. Produces a written plan at .agent/plans/<slug>.md.",
      "mode": "primary",
      "model": "anthropic/claude-opus-4-7",
      "temperature": 0.3,
      "permission": {
        "edit": "allow",
        "bash": "deny",
        "webfetch": "allow",
        "ast_grep": "deny",
        "tsc_check": "deny",
        "eslint_check": "deny",
        "todo_scan": "allow",
        "comment_check": "allow",
        "question": "allow",
        "serena": "allow",
        "memory": "allow",
        "git": "allow",
        "playwright": "deny",
        "linear": "allow"
      },
      "prompt": "{file:../../.claude/agents/plan.md}"
    },
    "build": {
      "description": "Executes a written plan. Runs tests inline, gates completion on QA review.",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-6",
      "temperature": 0.1,
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "allow",
          "git push *": "allow",
          "git push --force*": "deny",
          "git push -f *": "deny",
          "git push * main*": "deny",
          "git push * master*": "deny",
          "git clean *": "deny",
          "git reset --hard*": "ask",
          "git checkout *": "ask",
          "git worktree *": "ask",
          "rm -rf *": "deny",
          "chmod +x *": "allow",
          "chmod -x *": "allow",
          "chmod *": "deny",
          "chown *": "deny",
          "sudo *": "deny"
        },
        "webfetch": "allow",
        "ast_grep": "allow",
        "tsc_check": "allow",
        "eslint_check": "allow",
        "todo_scan": "allow",
        "comment_check": "allow",
        "question": "allow",
        "serena": "allow",
        "memory": "allow",
        "git": "allow",
        "playwright": "allow",
        "linear": "allow"
      },
      "prompt": "{file:../../.claude/agents/build.md}"
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git push *": "ask",
      "git push --force*": "deny",
      "git push -f *": "deny",
      "git clean *": "deny",
      "git reset --hard*": "ask",
      "git checkout *": "ask",
      "git worktree *": "ask",
      "rm -rf *": "deny",
      "rm -r *": "ask",
      "chmod +x *": "allow",
      "chmod -x *": "allow",
      "chmod *": "deny",
      "chown *": "deny",
      "sudo *": "deny"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      ".env": "deny",
      "secrets/**": "deny"
    },
    "write": {
      "*": "allow",
      "*.env": "deny",
      ".env": "deny",
      "secrets/**": "deny"
    },
    "external_directory": {
      "~/.glorious/worktrees/**": "allow"
    }
  }
}
